{
  "name": "kora",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "db:push": "turbo run db:push --filter=@kora/db",
    "db:seed": "turbo run db:seed --filter=@kora/db",
    "db:studio": "turbo run db:studio --filter=@kora/db",
    "setup:admin": "bash scripts/setup-admin.sh"
  },
  "devDependencies": {
    "turbo": "^2.9.16",
    "typescript": "^5.0.0"
  },
  "packageManager": "npm@10.0.0"
}
