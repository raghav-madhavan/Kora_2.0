# Database (Supabase)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# Auth (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Admin app uses / after sign-in; student app uses /dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# AI
OPENAI_API_KEY=sk-...
MATCHING_ENGINE_URL=http://localhost:8000

# QR Verification
QR_HMAC_SECRET=change_this_to_a_random_64_char_string

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# Admin bootstrap (dev only)
# Set to your Clerk email to auto-assign SCHOOL_ADMIN on first sign-in
SEED_ADMIN_EMAIL=you@schooldistrict.edu
